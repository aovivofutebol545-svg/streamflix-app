{
  "expo": {
    "name": "Streamflix Free",
    "slug": "streamflix-free",
    "version": "2.0.4",
    "orientation": "portrait",
    "scheme": "streamflix",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": ["**/*"],
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 30000,
      "url": "https://soothing-lamentation366.runable.site/updates"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kaiquealmeida.streamflix"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0F1419"
      },
      "package": "com.kaiquealmeida.streamflix",
      "permissions": ["android.permission.INTERNET"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0C14",
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      "expo-screen-orientation"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c473e866-5eb7-4972-a2d9-133ae9c11147"
      }
    },
    "owner": "kaiquealmeida"
  }
}
