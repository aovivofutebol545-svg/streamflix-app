{
  "cli": {
    "version": ">= 18.0.0",
    "requireCommit": false
  },
  "build": {
    "production": {
      "node": "20.0.0",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.themoviedb.org/3"
      }
    },
    "preview": {
      "node": "20.0.0"
    },
    "development": {
      "node": "20.0.0",
      "developmentClient": true
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      }
    }
  }
}
